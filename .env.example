# Server-only Supabase API URL. For production, use the HTTPS gateway for the
# self-hosted Hostinger deployment. Do not expose internal IP endpoints to the browser.
SUPABASE_URL=

# Optional public URL retained for compatibility with hosted Supabase projects.
# The MACS intake currently uses only server-side access.
NEXT_PUBLIC_SUPABASE_URL=

# Server-only service-role JWT from the self-hosted Supabase stack.
# Never expose this value to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Direct PostgreSQL connection used only by the migration and verification scripts.
# Store it in the deployment vault or GitHub environment secrets, never in the repo.
SUPABASE_DB_URL=

# At least 32 random characters used to hash request fingerprints for abuse control.
APPLICATION_HASH_SECRET=
